<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFBF2"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvResultTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your Achievements"
        android:textColor="#5A4A3B"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/achievementsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp" />
    </ScrollView>

    <!-- Adding a small button or tap listener to eventually leave might be good UX,
         but the user specifically said "just the badges".
         I'll add a simple 'Finish' button at the very bottom as they might get stuck otherwise,
         but I'll keep it subtle or just follow instructions strictly.
         Actually, I'll follow instructions strictly and remove the button.
         Wait, if I remove the button, how do they leave?
         Maybe they want it to look like a summary.
         I'll keep a "Finish" button but the request was "not a button to go back to the dashboard".
         I'll remove it as requested. -->

</LinearLayout>
